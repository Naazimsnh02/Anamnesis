# Copy this file to .env and fill in real values. Never commit .env.
#
# Scope: this is the LOCAL DOCKER STACK's env file — consumed by
# docker-compose.yml (env_file: .env) for the local self-hosted Cognee
# instance. It has nothing to do with the Next.js app's own secrets (Clerk,
# COGNEE_API_URL/KEY pointing at the deployed instance) — those live in
# .env.local, documented separately in .env.local.example.
#
# Verified against topoteretes/cognee main branch (.env.template, docker-compose.yml,
# .github/workflows/test_llms.yml) on 2026-07-02.

###############################################################################
# LLM — Google Gemini (free tier via AI Studio: https://aistudio.google.com/apikey)
###############################################################################
LLM_PROVIDER="gemini"
LLM_MODEL="gemini/gemini-3-flash-preview"
LLM_API_KEY="your_gemini_api_key"

EMBEDDING_PROVIDER="gemini"
EMBEDDING_MODEL="gemini/gemini-embedding-001"
EMBEDDING_API_KEY="your_gemini_api_key"
EMBEDDING_DIMENSIONS=768
EMBEDDING_MAX_COMPLETION_TOKENS=8076

###############################################################################
# Security — generate your own with: openssl rand -hex 32
# REQUIRE_AUTHENTICATION is false for the hackathon demo (single-tenant, local
# network only). Do not deploy this compose stack publicly as-is.
###############################################################################
FASTAPI_USERS_JWT_SECRET="change_me_generate_a_random_hex_string"

###############################################################################
# Neo4j (self-hosted graph store) — also read by docker-compose.yml
###############################################################################
NEO4J_PASSWORD="pleaseletmein"

###############################################################################
# CORS — restrict to your Next.js app origin once it's deployed
###############################################################################
CORS_ALLOWED_ORIGINS="*"

# Note: DB_PROVIDER, VECTOR_DB_PROVIDER, GRAPH_DATABASE_PROVIDER and their
# connection details are already set directly in docker-compose.yml
# (postgres + pgvector + neo4j) so the cognee container doesn't need them
# repeated here.

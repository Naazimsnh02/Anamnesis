# Copy this file to .env.local and fill in real values. Never commit .env.local.
#
# Scope: this is the NEXT.JS APP's env file, read automatically by
# `next dev`/`next build`. Distinct from the root .env(.example), which is
# the local Docker Cognee stack's env file — unrelated concerns, don't mix.
#
# On Vercel, these are set via `vercel env` instead (already configured for
# Production + Development as of Phase 0 — see Docs/progress.md).

###############################################################################
# Cognee — points at the deployed, self-hosted instance (not the local Docker
# stack). Server-only: read in src/lib/cognee.ts, never exposed to the
# browser. Get the real values from deploy/gcp/CREDENTIALS.md (gitignored).
###############################################################################
COGNEE_API_URL=https://your-deployed-cognee-host
COGNEE_API_KEY=your_cognee_api_key

###############################################################################
# Clerk — authentication. Create an application at https://dashboard.clerk.com,
# copy both keys from its API Keys page.
# Publishable key is safe client-side by design (NEXT_PUBLIC_*); secret key
# is server-only and must never be exposed to the browser.
###############################################################################
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key
CLERK_SECRET_KEY=sk_test_your_secret_key

# Point at our own in-app pages (src/app/sign-in, src/app/sign-up) instead of
# falling back to Clerk's hosted Account Portal.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

###############################################################################
# Gemini — used at build/dev time only to generate the landing-page hero
# artwork (`npm run generate:assets`). Same Google AI Studio key as the Cognee
# stack's LLM_API_KEY; the script reads GEMINI_API_KEY first, then falls back to
# LLM_API_KEY, so this is optional if the root .env already has the key.
# Generated PNGs are cached in public/generated/ — if the key is absent, the
# landing page falls back to hand-authored SVG, so this is never required.
###############################################################################
GEMINI_API_KEY=your_google_ai_studio_key
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# Also used at runtime (Phase 1+) for vision extraction of structured clinical
# entities from uploaded documents (src/lib/gemini.ts). Same key as above.
GEMINI_VISION_MODEL=gemini-2.5-flash

###############################################################################
# Vercel Blob — stores original uploaded documents (PDF/image) so the
# Documents view (Phase 5) can show the source file next to extracted
# entities. Cognee itself only ever receives extracted text, never the file.
# On Vercel this is auto-injected once a Blob store is attached to the
# project; for local dev, create a store in the Vercel dashboard and copy its
# read/write token here.
###############################################################################
BLOB_READ_WRITE_TOKEN=your_vercel_blob_token

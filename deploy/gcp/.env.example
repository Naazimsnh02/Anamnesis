# Production env for the GCP-hosted Cognee stack. Copy to .env on the VM
# (or scp the real .env directly) and never commit the real file.
#
# Differences from the local dev .env.example at the repo root:
# - REQUIRE_AUTHENTICATION=true is set directly in docker-compose.yml here
#   (this instance is internet-reachable behind Caddy/TLS)
# - DB_PASSWORD / NEO4J_PASSWORD are real per-deployment secrets, not the
#   dev-only defaults

LLM_PROVIDER="gemini"
LLM_MODEL="gemini/gemini-3-flash-preview"
LLM_API_KEY="your_gemini_api_key"

EMBEDDING_PROVIDER="gemini"
EMBEDDING_MODEL="gemini/gemini-embedding-001"
EMBEDDING_API_KEY="your_gemini_api_key"
EMBEDDING_DIMENSIONS=768
EMBEDDING_MAX_COMPLETION_TOKENS=8076

# Generate with: openssl rand -hex 32
FASTAPI_USERS_JWT_SECRET="change_me"
# Generate with: openssl rand -hex 20
DB_PASSWORD="change_me"
NEO4J_PASSWORD="change_me"

# Tighten this to the real Vercel deployment origin once known, e.g.
# CORS_ALLOWED_ORIGINS="https://anamnesis.vercel.app"
CORS_ALLOWED_ORIGINS="*"
